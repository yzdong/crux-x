# preflight.env — operator-specific infra actuals consumed by the
# CRUX-Land scripts on the controller VM.
#
# Copy to ~/.crux-land/preflight.env on the controller and fill in.
# This file is gitignored; the values mirror your per-run manifest's
# "Resolved infra" section (see manifest-template.md).
#
# provision_controller.sh writes this file automatically from the
# manifest at provision time. Edit by hand only if you've drifted from
# the manifest deliberately.

# Required. Your GCP project ID (hosts GSM secrets and the GCS
# artifact bucket).
PROJECT=

# Required. Your GCS bucket name (no gs:// prefix). Will be referenced
# as gs://${BUCKET}/ throughout.
BUCKET=

# GCP zone for the controller VM (default us-central1-a).
ZONE=us-central1-a

# Controller VM name in GCE (default crux-land-ctrl).
CONTROLLER_VM=crux-land-ctrl

# Optional. If set, overrides the GSM-fallback lookup of the sink
# phone/email used by preflight checks. Leave empty to read from GSM
# (crux-land-sink-phone / crux-land-sink-email).
SINK_PHONE_NUMBER=
SINK_EMAIL_ADDRESS=
